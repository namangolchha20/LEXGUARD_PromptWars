# API base URL (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket base URL (defaults to ws://localhost:8000)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# If you use another port or open the app via your LAN IP, add every origin to
# API_CORS_ORIGINS in the repo root .env (must match the browser address bar exactly):
# API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://192.168.4.111:3001
