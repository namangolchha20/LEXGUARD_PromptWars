# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=lexguard
LOG_LEVEL=INFO

# ── API (apps/api) ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ── Web (apps/web) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://lexguard:lexguard@localhost:5432/lexguard

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Workers ──────────────────────────────────────────────────
ANALYZE_WORKER_CONCURRENCY=2

# ── Ingestion ────────────────────────────────────────────────
INGESTION_TEMP_DIR=data/temp
INGESTION_OUTPUT_DIR=data/parsed
INGESTION_MAX_FILE_SIZE_MB=50
INGESTION_WORKER_CONCURRENCY=2
INGESTION_OCR_MIN_CHARS_PER_PAGE=30

# ── Gemini / Clause extraction ─────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY=1.0
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_CONCURRENCY=5
CLAUSE_OUTPUT_DIR=data/clauses

# ── Risk analysis ────────────────────────────────────────────
RISK_OUTPUT_DIR=data/risk
RISK_LLM_ENHANCEMENT_THRESHOLD=0.3
RISK_RULE_WEIGHT=0.55
RISK_LLM_WEIGHT=0.45

# ── Consequence simulation ─────────────────────────────────────
CONSEQUENCE_OUTPUT_DIR=data/consequences

# ── Orchestrator ───────────────────────────────────────────────
ORCHESTRATOR_STATE_DIR=data/orchestrator
ORCHESTRATOR_MAX_RETRIES=2

# ── Benchmark comparison ───────────────────────────────────────
BENCHMARK_OUTPUT_DIR=data/benchmarks
